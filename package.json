{
  "name": "whoopper",
  "version": "0.1.2",
  "description": "The definitive WHOOP API client — zero runtime deps, full API coverage",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "whoop",
    "api",
    "health",
    "fitness",
    "recovery",
    "sleep",
    "hrv",
    "heart-rate"
  ],
  "author": "car1os",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/car1os/whoopper.git"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
